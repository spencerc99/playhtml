{
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "es2019", "dom"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "module": "esnext",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "playhtml": ["packages/playhtml/src"],
      "@playhtml/react": ["packages/react/src"],
      "@playhtml/common": ["packages/common/src"],
      "@extension/*": ["extension/src/*"]
    }
  },
  "include": [],
  "exclude": [
    "node_modules/*",
    "**/__tests__/*",
    "**/dist"
  ]
}
